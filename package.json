{
  "name": "webpush-scheduler",
  "type": "module",
  "scripts": {
    "start": "node src/main.ts",
    "dev": "node --watch src/main.ts",
    "test:env": "node --test tests/env/**/*.test.ts",
    "test:jsonStore": "node --test tests/jsonStore/**/*.test.ts",
    "test:sqliteStore": "node --test tests/sqliteStore/**/*.test.ts",
    "test:integration": "node --test tests/integration/**/*.test.ts",
    "test:playwright": "npx playwright test"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^24.6.2"
  },
  "engines": {
    "node": ">= 22.18.0"
  }
}
